{
  "name": "opena2a-cli",
  "version": "0.10.11",
  "description": "Unified CLI for the OpenA2A security platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opena2a": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/semantic/command-index.json dist/semantic/",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "release-smoke:corpus": "tsx scripts/release-smoke-corpus.ts",
    "release-smoke:init": "tsx scripts/release-smoke-init.ts",
    "release-smoke:comply": "tsx scripts/release-smoke-comply.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@opena2a/aicomply": "2.2.0",
    "@opena2a/cli-ui": "0.5.2",
    "@opena2a/contribute": "0.1.0",
    "@opena2a/credential-patterns": "0.1.2",
    "@opena2a/registry-client": "0.2.0",
    "@opena2a/shared": "0.1.0",
    "@opena2a/telemetry": "0.3.0",
    "ai-trust": "^0.2.23",
    "commander": "^13.1.0",
    "hackmyagent": "0.25.0",
    "secretless-ai": "^0.14.1"
  },
  "optionalDependencies": {
    "@opena2a/aim-core": "*"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://github.com/opena2a-org/opena2a/tree/main/packages/cli",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/opena2a-org/opena2a.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai",
    "agent",
    "security",
    "scanner",
    "mcp",
    "credentials",
    "identity"
  ]
}
