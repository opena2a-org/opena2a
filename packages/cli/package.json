{
  "name": "opena2a-cli",
  "version": "0.8.19",
  "description": "Unified CLI for the OpenA2A security platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opena2a": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/semantic/command-index.json dist/semantic/",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@opena2a/contribute": "0.1.0",
    "@opena2a/shared": "0.1.0",
    "ai-trust": "^0.2.23",
    "commander": "^13.1.0",
    "hackmyagent": "^0.17.0",
    "secretless-ai": "^0.14.1"
  },
  "optionalDependencies": {
    "@opena2a/aim-core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://github.com/opena2a-org/opena2a/tree/main/packages/cli",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/opena2a-org/opena2a.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai",
    "agent",
    "security",
    "scanner",
    "mcp",
    "credentials",
    "identity"
  ]
}
